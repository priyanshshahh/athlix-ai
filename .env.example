# ATHLIX AI — environment configuration
# Copy to `.env.local` and fill in real values. Both keys are SERVER-SIDE only.
# There is deliberately no NEXT_PUBLIC_* key — nothing secret reaches the browser.

# BALLDONTLIE API key — powers live NBA player search, bio, and team results.
# Get one (free tier) at https://www.balldontlie.io
# If unset: live search returns 503 and player pages show an explicit offline state.
BALLDONTLIE_API_KEY=

# OpenRouter API key — powers the ATHLIX Intelligence chat (DeepSeek).
# Get one at https://openrouter.ai/keys
# If unset: /api/chat streams a clearly-labeled canned demo response instead.
OPENROUTER_API_KEY=

# Number of trusted reverse-proxy / edge hops in front of the app, used to
# derive a trustworthy client IP for rate limiting from X-Forwarded-For.
# Vercel's edge = 1; a bare origin = 0 (leave unset). When 0/unset the limiter
# does not trust the client-settable leftmost XFF entry and falls back to a
# composite key — see lib/rate-limit.ts and docs/CODE-AUDIT.md for the caveats.
TRUSTED_PROXY_HOPS=
